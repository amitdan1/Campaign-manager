# ============================================
# Performance Marketing System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- OpenAI (Required for AI-powered agents) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
DATABASE_URL=sqlite:///marketing.db

# --- Budget (NIS/month) ---
BUDGET_TOTAL=500
BUDGET_GOOGLE_ADS=300
BUDGET_FACEBOOK=200

# --- SendGrid (Email automation) ---
# Sign up at https://sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=ofirassulin.design@gmail.com

# --- Twilio (WhatsApp automation) ---
# Sign up at https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Google Ads API ---
# Set up at https://developers.google.com/google-ads/api
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# --- Facebook Marketing API ---
# Set up at https://developers.facebook.com
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_AD_ACCOUNT_ID=
FACEBOOK_PIXEL_ID=

# --- Google Ads Conversion Tracking ---
# Found in Google Ads > Tools > Conversions > your conversion action
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL=

# --- Flask ---
FLASK_SECRET_KEY=change-me-in-production
FLASK_DEBUG=true
